---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import IconStructural from '../components/icons/IconStructural.astro';
import IconProjectManagement from '../components/icons/IconProjectManagement.astro';
import IconMEP from '../components/icons/IconMEP.astro';

const stats = [
    { value: "15", label: "Years in Business" },
    { value: "11", label: "States Licensed" },
    { value: "100+", label: "Projects Completed" },
    { value: "$5B+", label: "Total Project Value" }
];
---

<Layout title="DECON LLC - Engineering Excellence Since 2010">
  <Header />
  <main>
    <section class="hero">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <h1 class="hero-title">Engineering Excellence. Delivered.</h1>
        <p class="hero-subtitle">A Houston-based, multidisciplinary engineering firm delivering innovative, resilient, and cost-effective solutions for public and private sector clients.</p>
        <a href="/about" class="hero-cta">Learn More About Us</a>
      </div>
    </section>

    <section class="services">
      <div class="section-container">
        <h2 class="section-title">Core Disciplines</h2>
        <p class="section-subtitle">We provide a comprehensive suite of services, from initial concept to final construction, specializing in civil, structural, and architectural design.</p>
        <div class="service-grid">
          <div class="service-card">
            <div class="service-icon">
              <IconStructural />
            </div>
            <h3>Bridge & Structural</h3>
            <p>Designing the backbone of critical infrastructure with a focus on safety, resilience, and efficiency.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <IconProjectManagement />
            </div>
            <h3>Roadway & Drainage</h3>
            <p>Expert roadway and drainage design to ensure optimal performance and public safety.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <IconMEP />
            </div>
            <h3>Building Design</h3>
            <p>Integrated architectural and MEP solutions for functional, sustainable, and high-performance buildings.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="section-container stats-grid">
            {stats.map(stat => (
                <div class="stat-item">
                    <span class="stat-value">{stat.value}</span>
                    <span class="stat-label">{stat.label}</span>
                </div>
            ))}
        </div>
    </section>

    <section class="featured-projects">
      <div class="section-container">
        <h2 class="section-title">Featured Projects</h2>
        <p class="section-subtitle">A selection of our work, showcasing our commitment to excellence and innovation across sectors.</p>
        <div class="project-grid">
          <!-- Projects remain the same -->
          <a href="/projects/1" class="project-card">
            <div class="project-image" style="background-image: url('https://images.unsplash.com/photo-1428790067576-23423b3b2742?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D')"></div>
            <div class="project-content">
              <h4>Corporate Headquarters</h4>
              <span>Commercial</span>
            </div>
          </a>
          <a href="/projects/2" class="project-card">
            <div class="project-image" style="background-image: url('https://images.unsplash.com/photo-1541696492338-06b539455338?q=80&w=1974&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D')"></div>
            <div class="project-content">
              <h4>Cityscape Bridge</h4>
              <span>Infrastructure</span>
            </div>
          </a>
           <a href="/projects/3" class="project-card">
            <div class="project-image" style="background-image: url('https://images.unsplash.com/photo-1600585154340-be6164a83639?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D')"></div>
            <div class="project-content">
              <h4>Modern Residence</h4>
              <span>Residential</span>
            </div>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* --- Hero Section --- */
  .hero {
    position: relative;
    background-image: url('https://images.unsplash.com/photo-1593113595449-869c62a8069a?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    color: var(--color-background);
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
  }

  .hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(26, 26, 26, 0.7); }
  .hero-content { position: relative; z-index: 1; padding: 2rem; max-width: 800px; }
  .hero-title { font-size: 4.5rem; font-weight: 700; color: var(--color-background); margin-bottom: 1rem; text-shadow: 2px 2px 10px rgba(0,0,0,0.3); }
  .hero-subtitle { font-size: 1.25rem; font-weight: 300; margin-bottom: 2.5rem; opacity: 0.9; max-width: 650px; margin-left: auto; margin-right: auto; }
  .hero-cta { background-color: var(--color-accent); color: var(--color-background); padding: 1rem 2.5rem; border-radius: 50px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; transition: background-color 0.3s ease, transform 0.3s ease; box-shadow: var(--shadow-md); }
  .hero-cta:hover { background-color: #0056b3; transform: translateY(-3px); }

  /* --- Services Section --- */
  .services { background-color: var(--color-background); padding: 6rem 2rem; }
  .section-container { max-width: 1200px; margin: 0 auto; text-align: center; }
  .section-title { font-size: 2.75rem; margin-bottom: 1rem; }
  .section-subtitle { font-size: 1.1rem; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto 4rem; }
  .service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem; }
  .service-card { background-color: var(--color-surface); padding: 2.5rem; border: 1px solid var(--color-border); border-radius: 8px; text-align: left; box-shadow: var(--shadow-sm); transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .service-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); }
  .service-icon { margin-bottom: 1.5rem; color: var(--color-accent); }
  .service-card h3 { font-size: 1.5rem; margin-bottom: 1rem; color: var(--color-primary); }
  .service-card p { color: var(--color-text-secondary); line-height: 1.7; }

  /* --- Stats Section --- */
  .stats-section { background-color: var(--color-primary); color: var(--color-background); padding: 5rem 2rem; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; text-align: center; max-width: 1000px; }
  .stat-item { padding: 1rem; }
  .stat-value { display: block; font-size: 3.5rem; font-weight: 700; color: var(--color-accent); }
  .stat-label { font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8; }

  /* --- Featured Projects Section --- */
  .featured-projects { background-color: var(--color-surface); padding: 6rem 2rem; }
  .project-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2rem; }
  .project-card { position: relative; overflow: hidden; border-radius: 8px; box-shadow: var(--shadow-md); min-height: 450px; display: flex; align-items: flex-end; color: var(--color-background); transition: transform 0.4s ease, box-shadow 0.4s ease; }
  .project-card:hover { transform: scale(1.03); box-shadow: var(--shadow-lg); }
  .project-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-size: cover; background-position: center; transition: transform 0.4s ease; }
  .project-card:hover .project-image { transform: scale(1.1); }
  .project-content { position: relative; z-index: 2; padding: 2rem; width: 100%; background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%); }
  .project-content h4 { font-size: 1.75rem; color: var(--color-background); margin-bottom: 0.5rem; }
  .project-content span { font-weight: 500; color: var(--color-accent); text-transform: uppercase; letter-spacing: 1px; font-size: 0.85rem; }

  @media (max-width: 768px) {
    .hero-title { font-size: 3rem; }
    .stat-value { font-size: 2.75rem; }
  }
</style>
