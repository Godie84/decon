---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects, type Project } from '../../data/projects';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
  }));
}

const { id } = Astro.params;
const project = projects.find((p) => p.id === id);

if (!project) {
  return Astro.redirect('/404');
}
---

<Layout title={`Deconeng | ${project.title}`}>
  <Header />
  <main class="project-detail">
    <article>
      <header class="project-header">
        <div class="section-container">
          <span class="project-category">{project.category}</span>
          <h1 class="project-title">{project.title}</h1>
        </div>
      </header>

      <div class="project-image-container">
        <img src={project.img} alt={project.img_alt} />
      </div>

      <div class="project-body">
        <div class="project-content">
          <h2 class="section-title-small">Project Overview</h2>
          <p>{project.description}</p>
        </div>
        <aside class="project-sidebar">
          <div class="sidebar-widget">
            <h4>Project Details</h4>
            <ul>
              <li><strong>Published:</strong> {new Date(project.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</li>
              <li><strong>Category:</strong> {project.category}</li>
            </ul>
          </div>
          <div class="sidebar-widget">
            <h4>Disciplines</h4>
            <ul class="tags">
              {project.tags.map(tag => <li>{tag}</li>)}
            </ul>
          </div>
        </aside>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .project-header {
    background-color: var(--color-surface);
    padding: 4rem 2rem;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .section-container { max-width: 900px; margin: 0 auto; }

  .project-category {
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    display: block;
  }

  .project-title { font-size: 3.5rem; color: var(--color-primary); }

  .project-image-container {
    max-width: 1400px;
    margin: 4rem auto;
    padding: 0 2rem;
    box-shadow: var(--shadow-lg);
    border-radius: 8px;
    overflow: hidden;
  }
  
  .project-image-container img { width: 100%; height: auto; }

  .project-body {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto 6rem;
    padding: 0 2rem;
  }

  .section-title-small {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 0.75rem;
    display: inline-block;
  }

  .project-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .sidebar-widget {
    background-color: var(--color-surface);
    padding: 2rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .sidebar-widget h4 {
    font-size: 1.2rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .sidebar-widget ul {
    list-style: none;
  }

  .sidebar-widget ul li {
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-secondary);
  }
  
  .sidebar-widget ul li strong { color: var(--color-text-primary); font-weight: 500; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tags li {
    background-color: var(--color-accent);
    color: var(--color-background);
    padding: 0.4rem 0.8rem;
    border-radius: 50px;
    font-size: 0.8rem !important;
    font-weight: 500;
  }

  /* Responsive Adjustments */
  @media (max-width: 992px) {
    .project-body {
      grid-template-columns: 1fr;
    }
    .project-header {
        padding: 3rem 1rem;
    }
    .project-title { font-size: 2.5rem; }
  }
</style>
