---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';
---

<Layout title="Our Projects - Deconeng">
  <Header />
  <main>
    <section class="page-hero">
      <div class="section-container">
        <h1 class="page-title">Our Work</h1>
        <p class="page-subtitle">A comprehensive portfolio of our engineering and design projects across various sectors.</p>
      </div>
    </section>

    <section class="projects-gallery">
      <div class="section-container">
        <div class="project-grid">
          {projects.map(project => (
            <a href={`/projects/${project.id}`} class="project-card">
              <div class="project-image" style={`background-image: url('${project.imageUrl}')`}></div>
              <div class="project-content">
                <h4>{project.title}</h4>
                <span>{project.category}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* --- Page Hero --- */
  .page-hero {
    background-color: var(--color-surface);
    text-align: center;
    padding: 5rem 2rem;
  }
  .page-title {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .page-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }

  /* --- Projects Gallery --- */
  .projects-gallery {
    padding: 6rem 2rem;
  }
  
  .section-container { 
    max-width: 1200px; 
    margin: 0 auto; 
  }

  /* Reusing styles from the homepage for consistency */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .project-card {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: var(--shadow-md);
    min-height: 450px;
    display: flex;
    align-items: flex-end;
    color: var(--color-background);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  
  .project-card:hover {
      transform: scale(1.03);
      box-shadow: var(--shadow-lg);
  }

  .project-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-image {
    transform: scale(1.1);
  }

  .project-content {
    position: relative;
    z-index: 2;
    padding: 2rem;
    width: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
  }

  .project-content h4 {
    font-size: 1.75rem;
    color: var(--color-background);
    margin-bottom: 0.5rem;
  }

  .project-content span {
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.85rem;
  }
</style>