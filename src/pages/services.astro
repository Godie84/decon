---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: "Bridge Design & Construction Engineering",
    description: "Bridge design and construction engineering are our core competencies. For the last fifteen years, we have mostly focused on design-build and Public-Private Partnerships (P3) projects for the Departments of Transportation in the states where we practice. With extensive experience in diverse bridge types and structural systems, utilizing a range of materials, we specialize in delivering innovative solutions to complex technical challenges through the application of advanced technologies.",
    stats: [
      { value: "100+", label: "Bridges Designed" },
      { value: "15", label: "Years Experience" }
    ],
    capabilities: ["Value Engineering", "Structural/Bridge Design Optimization", "Bridge/Structural Shop Drawings", "Bridge Erection Engineering & Procedures", "Bridge Inspections & Load Rating Analysis", "Bridge Demolition & Procedures", "Bridge Rehabilitations & Retrofit", "Temporary Shoring, Formwork, Falsework & Temporary Bracing Design", "Retaining Wall Design", "Deep Foundation Repair Procedures", "Structural Deficiency Repairs", "Traffic Control Plans & Phased Construction", "Field Design Changes (FDC)", "Precast & Prestressed Concrete Structures", "Ancillary Highway Structures"],
    featured: ["I-35 NEX Central Project - $1.59B elevated highway", "I-285 and SH-400 Interchange, Atlanta, GA", "SH 146 and SH 3 Bridge Replacement, Galveston County, TX"]
  },
  {
    title: "Roadway & Drainage",
    description: "DECON offers specialized Roadway and Drainage services, concentrating on Design-Build, PS&E, and trail development projects. With a strong presence in multiple states, we have established a reputation for excellence and unequaled customer service for Departments of Transportation, local and regional agencies, and toll road authorities. DECON's expertise lies in identifying opportunities to reduce project costs by optimizing construction sequencing and improving traffic safety operations.",
    stats: [
      { value: "500+", label: "Miles Designed" },
      { value: "50+", label: "Roadway Projects" }
    ],
    capabilities: ["Roadway/Highway Design", "Temporary & Final Roadway Drainage Optimization", "Traffic Control Plan (TCP)", "Traffic Modeling", "Hydraulic and Hydrologic Studies", "3-Dimensional Traffic Modeling", "Final and Temporary Drainage Design", "Retaining Walls", "Signing and Pavement Markings", "Traffic Signalization", "Stormwater Pollution Prevention Plan (SW3P)", "Utility Conflicts Management & Resolutions", "Feasibility Studies for Bicycle-Pedestrian Facilities", "Intersection Improvements & Signal Timing", "Envision Sustainability Analysis"],
    featured: ["SH 99 at Kingwood Road - $1.3B, 52.8-mile Grand Parkway project", "Sam Houston Tollway East - AET conversion", "Trails Connectivity: Tollways to Trailways, Harris County, TX"]
  },
  {
    title: "Building Design",
    description: "At DECON, we provide comprehensive civil engineering and structural design services for buildings across various sectors, including residential, commercial, institutional, and industrial applications. Our innovative approach, particularly through the use of BIM-compliant systems, enhances building efficiency and promotes environmental sustainability. We deliver LOD 100-500 models with 3D visualization, 4D budgeting, and 5D scheduling capabilities.",
    stats: [
      { value: "50+", label: "Buildings Designed" },
      { value: "BIM", label: "LOD 100-500" }
    ],
    capabilities: ["Building Structural Analysis & Design", "Construction Plans & Documents Preparation", "Engineering Calculations Reports", "Foundations Design", "Retaining Walls & Soil Stability Analysis", "Value Engineering", "Construction Structural Special Inspections", "Construction Engineering Support", "Civil Site Design", "Peer Review & QA/QC Services", "BIM Implementation", "3D, 4D Budgeting, 5D Scheduling"],
    featured: ["Cameron Bear Lane Warehouse - 150,000 SF facility", "Kaua Building - 18-floor residential tower", "Houston Quran Academy - 40,000 SF institutional building"]
  }
];

const precertCategories = {
    "Roadway & Planning": ["1.1.1 - Policy Planning", "1.2.1 - Systems Planning", "1.3.1 - Subarea/Corridor Planning", "1.4.1 - Land Planning/Engineering", "1.5.1 - Feasibility Studies", "3.2.1 - Route Studies and Schematic Design", "4.2.1 - Roadway Design", "4.4.1 - Freeway Interchanges", "4.5.1 - Constructability Review"],
    "Bridge & Structures": ["5.2.1 - Bridge Design", "5.3.1 - Multi-Level Interchange Design", "5.5.1 - Bridge Class Culvert Design", "5.6.1 - Structural Engineering for Overhead Sign Supports", "6.1.1 - Routine Bridge Inspection Team Leader", "6.2.1 - Complex Bridge Inspection Team Leader", "17.1.1 - Structural Engineering", "24.7.1 - Toll Plaza Design"],
    "Traffic & Safety": ["7.1.1 - Traffic Engineering Studies", "7.3.1 - Traffic Signal Timing", "8.1.1 - Signing, Pavement Marking, and Channelization", "8.3.1 - Signalization", "11.1.1 - Roadway Construction Management and Inspection", "23.11.1 - Plan Review"],
    "Specialized Services": ["10.4.3 - Pump Stations-Structures", "14.3.1 - Transportation Foundation Studies", "14.5.1 - Evaluation & Design of Geotechnical Related Structures", "18.2.1 - Subsurface Utility Engineering"]
};

---
<Layout title="Our Services - DECON LLC">
  <Header />
  <main>
    <section class="page-hero">
      <div class="section-container">
        <h1 class="page-title">Comprehensive Engineering Solutions</h1>
        <p class="page-subtitle">15 years of delivering innovative engineering solutions for complex challenges across infrastructure and building sectors.</p>
      </div>
    </section>

    <div class="services-anchor-nav">
        <div class="section-container">
            <a href="#bridge">Bridge Design</a>
            <a href="#roadway">Roadway & Drainage</a>
            <a href="#building">Building Design</a>
            <a href="#txdot">TxDOT Certifications</a>
        </div>
    </div>

    <!-- Services Sections -->
    {services.map((service, index) => (
      <section id={service.title.toLowerCase().split(' ')[0]} class:list={["service-section", { reverse: index % 2 !== 0 }]}>
        <div class="section-container service-grid">
          <div class="service-content">
            <h2 class="service-title">{service.title}</h2>
            <p class="service-description">{service.description}</p>
            <h3 class="subsection-title">Capabilities</h3>
            <ul class="capabilities-list">
              {service.capabilities.map(cap => <li>{cap}</li>)}
            </ul>
          </div>
          <aside class="service-sidebar">
            <div class="stats-box">
                {service.stats.map(stat => (
                    <div class="stat-item">
                        <span class="stat-value">{stat.value}</span>
                        <span class="stat-label">{stat.label}</span>
                    </div>
                ))}
            </div>
            <h3 class="subsection-title">Featured Projects</h3>
            <ul class="featured-list">
                {service.featured.map(feat => <li>{feat}</li>)}
            </ul>
          </aside>
        </div>
      </section>
    ))}

    <!-- TxDOT Precertification Section -->
    <section id="txdot" class="txdot-section">
        <div class="section-container">
            <h2 class="section-title">TxDOT Precertification</h2>
            <p class="section-subtitle">We are pre-certified in 24 work categories, demonstrating our broad expertise and qualification to lead and support diverse transportation projects for the Texas Department of Transportation.</p>
            <div class="txdot-grid">
                {Object.entries(precertCategories).map(([category, items]) => (
                    <div class="txdot-category">
                        <h4>{category}</h4>
                        <ul>
                            {items.map(item => <li>{item}</li>)}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="section-container">
        <h2>Ready to Discuss Your Project?</h2>
        <p>Our experienced team is ready to deliver innovative engineering solutions tailored to your needs.</p>
        <a href="/contact" class="cta-button">Contact Our Team</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Page Hero */
  .page-hero { background-color: var(--color-surface); text-align: center; padding: 5rem 2rem; }
  .page-title { font-size: 3.5rem; font-weight: 700; color: var(--color-primary); margin-bottom: 1rem; }
  .page-subtitle { font-size: 1.15rem; color: var(--color-text-secondary); max-width: 700px; margin: 0 auto; }
  .section-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  /* Anchor Nav */
  .services-anchor-nav { background: var(--color-surface); padding: 1rem 0; border-bottom: 1px solid var(--color-border); text-align: center; position: sticky; top: 0; background: var(--color-background); z-index: 10; }
  .services-anchor-nav a { margin: 0 1rem; font-weight: 600; color: var(--color-accent); text-decoration: none; transition: color 0.3s ease; }
  .services-anchor-nav a:hover { color: var(--color-primary); }

  /* Service Section */
  .service-section { padding: 6rem 0; border-bottom: 1px solid var(--color-border); }
  .service-section:nth-of-type(odd) { background-color: var(--color-background); }
  .service-section:nth-of-type(even) { background-color: var(--color-surface); }

  .service-grid { display: grid; grid-template-columns: 1fr; gap: 4rem; align-items: flex-start; }
  @media (min-width: 992px) { .service-grid { grid-template-columns: 2fr 1fr; } }
  
  .service-section.reverse .service-content { order: 2; }
  .service-section.reverse .service-sidebar { order: 1; }

  .service-title { font-size: 2.75rem; color: var(--color-primary); margin-bottom: 2rem; }
  .service-description { line-height: 1.8; color: var(--color-text-secondary); margin-bottom: 2rem; }
  .subsection-title { font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem; color: var(--color-text-primary); border-bottom: 2px solid var(--color-accent); padding-bottom: 0.5rem; display: inline-block; }
  
  .capabilities-list { list-style: none; padding: 0; columns: 2; gap: 0.75rem 2rem; }
  @media (max-width: 576px) { .capabilities-list { columns: 1; } }
  .capabilities-list li { position: relative; padding-left: 20px; margin-bottom: 0.75rem; color: var(--color-text-secondary); }
  .capabilities-list li::before { content: '\25AA'; font-size: 10px; position: absolute; left: 0; color: var(--color-accent); }

  /* Sidebar */
  .service-sidebar { position: sticky; top: 80px; }
  .stats-box { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; background: var(--color-primary); color: var(--color-background); padding: 2rem; border-radius: 8px; text-align: center; margin-bottom: 3rem; }
  .stat-value { display: block; font-size: 2.5rem; font-weight: 700; color: var(--color-accent); }
  .stat-label { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8; }
  
  .featured-list { list-style: none; padding: 0; }
  .featured-list li { background: var(--color-surface); padding: 1rem; border-radius: 5px; margin-bottom: 1rem; border-left: 3px solid var(--color-accent); font-weight: 500; }

  /* TxDOT Section */
  .txdot-section { padding: 6rem 0; text-align: center; }
  .section-title { font-size: 2.75rem; margin-bottom: 1rem; }
  .txdot-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; text-align: left; margin-top: 3rem; }
  .txdot-category h4 { font-size: 1.25rem; color: var(--color-primary); margin-bottom: 1rem; }
  .txdot-category ul { list-style: none; padding: 0; }
  .txdot-category li { margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--color-text-secondary); }
  
  /* CTA Section */
  .cta-section { background: var(--color-accent); color: var(--color-background); text-align: center; padding: 5rem 2rem; }
  .cta-section h2 { font-size: 2.75rem; margin-bottom: 1rem; }
  .cta-section p { font-size: 1.15rem; opacity: 0.9; margin-bottom: 2rem; }
  .cta-button { background-color: var(--color-background); color: var(--color-primary); padding: 1rem 3rem; border-radius: 50px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; transition: all 0.3s ease; box-shadow: var(--shadow-md); }
  .cta-button:hover { background-color: #f0f0f0; transform: translateY(-3px); color: var(--color-primary); }
</style>
