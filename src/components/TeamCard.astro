---
import type { TeamMember } from '../data/team.ts';

export interface Props {
    member: TeamMember;
}

const { member } = Astro.props;
---

<div class="team-card">
    <div class="card-image">
        <img src={member.imageUrl} alt={`Portrait of ${member.name}`} loading="lazy" />
    </div>
    <div class="card-content">
        <h3 class="member-name">{member.name}</h3>
        <p class="member-title">{member.title}</p>
        {member.credentials && member.credentials.length > 0 && (
            <div class="credentials">
                {member.credentials.map(cred => <span class="credential-tag">{cred}</span>)}
            </div>
        )}
    </div>
</div>

<style>
  .team-card {
    background-color: var(--color-surface);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .team-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .card-image img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    object-position: top;
  }

  .card-content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .member-name {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .member-title {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    flex-grow: 1;
  }

  .credentials {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: auto; /* Pushes credentials to the bottom */
  }

  .credential-tag {
    background-color: var(--color-accent-soft);
    color: var(--color-accent);
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 15px;
    font-weight: 500;
  }
</style>
