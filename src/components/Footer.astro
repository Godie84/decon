const year = new Date().getFullYear();
---

<footer>
  <div class="footer-container">
    <div class="footer-column about">
      <h4>DECON LLC</h4>
      <p>A Houston-based multidisciplinary engineering firm delivering innovative solutions. Engineering Excellence Since 2010.</p>
      <div class="company-ids">
        <span>DUNS: 079546386</span>
        <span>CAGE: 80M24</span>
        <span>UEI#: HFMHHDWH4PS4</span>
      </div>
    </div>
    <div class="footer-column links">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/projects">Projects</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
    <div class="footer-column contact">
      <h4>Contact Info</h4>
      <p>2 Riverway Dr. Unit 605<br>Houston, TX 77056</p>
      <p>Email: <a href="mailto:projects@deconeng.com">projects@deconeng.com</a></p>
      <p>Phone: <a href="tel:+18329170912">+1 (832) 917-0912</a></p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2025 DECON LLC. All Rights Reserved.</p>
  </div>
</footer>

<style>
  footer {
    background-color: var(--color-surface);
    color: var(--color-text-secondary);
    border-top: 1px solid var(--color-border);
  }

  .footer-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .footer-column h4 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .footer-column p, .footer-column li, .footer-column span {
    font-size: 0.95rem;
    line-height: 1.7;
  }
  
  .footer-column.about p {
    max-width: 320px;
    margin-bottom: 1rem;
  }

  .company-ids {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.85rem;
    opacity: 0.8;
  }

  .footer-column.links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-column.links a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .footer-column.contact a {
    color: var(--color-text-secondary);
    transition: color 0.3s ease;
  }

  .footer-column.contact a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .footer-bottom {
    text-align: center;
    padding: 1.5rem 2rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.9rem;
  }
</style>
